{
  "schemaVersion": 1,
  "id": "moneyhud",
  "version": "${version}",

  "name": "MoneyHUD",
  "description": "A premium economy HUD overlay that reads a scoreboard objective and displays the player's money with 3 configurable visual tiers. Designed for roleplay and economy maps.",
  "authors": [
    "elthisboy"
  ],
  "contact": {},

  "license": "CC0-1.0",
  "icon": "assets/moneyhud/icon.png",

  "environment": "client",

  "entrypoints": {
    "main": [
      "com.elthisboy.moneyhud.MoneyHud"
    ],
    "client": [
      "com.elthisboy.moneyhud.client.MoneyHudClient"
    ]
  },

  "mixins": [
    "moneyhud.mixins.json",
    {
      "config": "moneyhud.client.mixins.json",
      "environment": "client"
    }
  ],

  "depends": {
    "fabricloader": ">=0.18.6",
    "minecraft": "~1.21.1",
    "java": ">=21",
    "fabric-api": "*"
  }
}
